{
  "$schema": "https://modelcontextprotocol.io/schema/mcp-config",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-filesystem", "/tmp"],
      "enabled": false,
      "description": "Filesystem operations (read, write, list)"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "enabled": false,
      "description": "Git operations (status, log, diff)"
    }
  }
}