{
  "$schema": "https://modelcontextprotocol.io/schema/mcp-config",
  "mcpServers": {
    "sentiment": {
      "command": "python",
      "args": ["mcp_servers/sentiment_mcp_server.py"],
      "enabled": true,
      "description": "Sentiment classification using keyword analysis (positive/negative/neutral)"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "enabled": false,
      "description": "Filesystem operations (disabled - use builtin Read/Write instead)"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "enabled": false,
      "description": "Git operations (status, log, diff)"
    }
  }
}